# --- Servidor ---
PORT=3333
NODE_ENV=development

# URL do frontend, usada para configurar CORS e cookies
CLIENT_URL=http://localhost:5173

# --- Banco de dados ---
# Deve bater com as credenciais do docker-compose.yml na raiz do projeto
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# --- Autenticação (JWT) ---
# Gere segredos fortes em produção, ex: `openssl rand -base64 48`
JWT_ACCESS_SECRET=troque-este-segredo-de-access-token
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-token

# Tempo de vida dos tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
